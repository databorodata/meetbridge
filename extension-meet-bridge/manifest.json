{
  "manifest_version": 3,
  "name": "Meet Bridge (MVP)",
  "version": "0.1.0",
  "description": "Minimal UI to call local meet-bridge HTTP API (no audio yet).",
  "action": {
    "default_title": "Meet Bridge",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"]
}

