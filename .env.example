# Meet Assist — example configuration
# Copy to .env and fill in values:
#   cp .env.example .env

# ─── Cursor CLI ───────────────────────────────────────────────────────────────
# API key for calling agent in headless mode.
# Create at: https://cursor.com/dashboard/integrations → API Keys
CURSOR_API_KEY=

# ─── GitHub (optional) ─────────────────────────────────────────────────────
# Fine-grained PAT with read-only permissions.
# Required if you want the agent to view issues/PRs via `gh`.
#
# Create at: https://github.com/settings/tokens?type=beta
# Permissions → Repository permissions:
#   Contents:      Read-only
#   Issues:        Read-only
#   Pull requests: Read-only
#   Everything else: No access
#
# With a read-only token, `gh pr comment` and other mutations will fail with 403.
GITHUB_TOKEN=
