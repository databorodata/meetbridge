# Meet Assist — пример конфигурации
# Скопируй в .env и заполни значения:
#   cp .env.example .env

# ─── Cursor CLI ───────────────────────────────────────────────────────────────
# API-ключ для вызова agent в headless-режиме.
# Создать: https://cursor.com/dashboard/integrations → API Keys
CURSOR_API_KEY=

# ─── GitHub (опционально) ─────────────────────────────────────────────────────
# Fine-grained PAT с правами ТОЛЬКО на чтение.
# Нужен если хочешь чтобы агент мог смотреть issues/PR через `gh`.
#
# Создать: https://github.com/settings/tokens?type=beta
# Permissions → Repository permissions:
#   Contents:      Read-only
#   Issues:        Read-only
#   Pull requests: Read-only
#   Всё остальное: No access
#
# С read-only токеном `gh pr comment` и другие мутации упадут с 403.
GITHUB_TOKEN=

# ─── Репозиторий для агента ───────────────────────────────────────────────────
# Абсолютный путь к git-репозиторию, который будет анализировать агент.
# Пример: /Users/yourname/projects/myapp
MEET_BRIDGE_REPO=
