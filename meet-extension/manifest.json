{
  "manifest_version": 3,
  "name": "Meet Assist",
  "version": "0.2.0",
  "description": "Локальный мост + WhisperLive: транскрипт встречи и запрос к агенту.",
  "action": {
    "default_title": "Meet Assist",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs", "tabCapture"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "*://127.0.0.1/*",
    "*://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
